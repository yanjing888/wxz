            "h": 102,
            "n": 1
          },
          {
            "x": 556,
            "y": 286,
            "w": 102,
            "h": 86,
            "n": 2
          }
        ]
      },
      "guidePath": "steps/4.md"
    }
  },
  "reportGuidePath": "report-guide.md"
}
