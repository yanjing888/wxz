# 物小智 Dify 配置（唯一入口，与 config/ports.env 同级）
# 修改后重启后端生效。
#
# DIFY_BASE_URL     Dify 服务地址（所有接口共用，不变）
# DIFY_API_KEY      默认 API Key（文字问答、视觉纠错等）
# DIFY_WF_*         各工作流独立 Key（留空则回退 DIFY_API_KEY；安全监测必须单独填，Key 与默认不同）

DIFY_BASE_URL=http://188.18.18.149:5001/v1
DIFY_APP_MODE=chat

# 默认 Key（AI 助手 / 视觉纠错等原有应用）
DIFY_API_KEY=app-63cqGEHiCOJn7mkhYQkJSPhD

# 各工作流独立 Key（留空=使用 DIFY_API_KEY）
DIFY_WF_VISION_CORRECTION=
DIFY_WF_TEXT_ASSIST=
DIFY_WF_ENV_CHECK=app-fi5uo9Gic5FYVqUqhefApVWa
DIFY_WF_REPORT_GENERATE=

# 知识库检索（留空=使用 text-assist / DIFY_API_KEY）
DIFY_KB_API_KEY=
DIFY_KB_TOP_K=5
