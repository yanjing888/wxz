# 物小智 Dify 配置（唯一入口，与 config/ports.env 同级）
# 修改后请用 scripts\run-backend.bat 或 scripts\start.bat 重启后端（会读取本文件注入环境变量）。
# Spring Boot 不能直接 import .env 文件，请勿仅双击 IDE 运行而未加载本配置。
#
# DIFY_BASE_URL     Dify 服务地址（所有接口共用，不变）
# DIFY_API_KEY      默认 API Key（文字问答、视觉纠错等）
# DIFY_WF_*         各工作流独立 Key（留空则回退 DIFY_API_KEY；安全监测必须单独填，Key 与默认不同）
# DIFY_WF_*_MODE    单个应用调用模式覆盖；安全监测是 Workflow，所以填 workflow

DIFY_BASE_URL=http://188.18.66.215/v1
DIFY_APP_MODE=chat

# 默认 Key（AI 助手 / 视觉纠错等原有应用）
DIFY_API_KEY=app-01LooqFQIENoqkysAnTW6PZa

# 各工作流独立 Key（留空=使用 DIFY_API_KEY）
DIFY_WF_VISION_CORRECTION=
DIFY_WF_TEXT_ASSIST=
DIFY_WF_ENV_CHECK=app-WEurnJBVSE2lOpngVCMLYnfg
DIFY_WF_ENV_CHECK_MODE=workflow
DIFY_WF_REPORT_GENERATE=

# 知识库检索（留空=使用 text-assist / DIFY_API_KEY）
DIFY_KB_API_KEY=
DIFY_KB_TOP_K=5
